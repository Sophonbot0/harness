{
  "name": "harness-enforcer",
  "version": "2.0.0",
  "description": "Contract-driven quality enforcement plugin for OpenClaw — 9 tools, session isolation, autonomy features",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "smoke": "tsx test-smoke.ts",
    "analyze-runs": "node scripts/aggregate-run-summaries.mjs",
    "repair-artifacts": "node scripts/remediate-artifact-debt.mjs"
  },
  "files": [
    "index.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
